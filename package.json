{
  "name": "@philiprehberger/core-utils",
  "version": "0.2.8",
  "description": "Pure utility functions - formatting, pagination, slugs, class merging, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "peerDependencies": {
    "clsx": ">=2.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "clsx": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    }
  },
  "devDependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "utils",
    "format",
    "currency",
    "pagination",
    "slug",
    "tailwind",
    "cn"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-core-utils.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-core-utils#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-core-utils/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
